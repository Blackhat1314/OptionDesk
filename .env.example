# ─────────────────────────────────────────────────
# OptionsDesk — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# ──── Dhan API Credentials ────────────────────────
# Get these from https://login.dhan.co → My Profile → API
DHAN_CLIENT_ID=your_client_id_here
DHAN_ACCESS_TOKEN=your_access_token_here
DHAN_BASE_URL=https://api.dhan.co/v2
DHAN_WS_URL=wss://api-feed.dhan.co

# ──── Redis ───────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password   # uncomment if needed

# ──── Server ─────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# ──── Market Config ───────────────────────────────
RISK_FREE_RATE=0.065        # RBI Repo Rate (6.5%)
DEFAULT_INDEX=NIFTY

# ──── Admin Panel ─────────────────────────────────
# Change these before deploying to production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=OptionsDesk@Admin2026
ADMIN_JWT_SECRET=admin-super-secret-key-change-in-production-2026
